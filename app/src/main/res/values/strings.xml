    <!-- ── Privacy Policy ─────────────────────────────────────── -->
    <string name="privacy_title">PRIVACY POLICY</string>
    <string name="privacy_version">ScamShield · v1.0 · Effective immediately</string>
    <string name="privacy_section_collected">DATA COLLECTED</string>
    <string name="privacy_collected_body">ScamShield processes the following data locally on your device:\n\n• Message text from WhatsApp, Telegram, SMS and browsers — for scam analysis only\n• Sender names and app package identifiers\n• Incoming phone numbers for call risk scoring\n• App settings and detection thresholds\n• Threat history — stored in a local database on your device</string>
    <string name="privacy_section_usage">HOW DATA IS USED</string>
    <string name="privacy_usage_body">All collected data is used solely to:\n\n• Detect scam messages and calls in real time\n• Display risk warnings and overlay alerts\n• Maintain a local threat history for your review\n• Generate PDF security reports on request\n\nNo data is used for advertising, profiling or shared with third parties.</string>
    <string name="privacy_section_server">WHAT IS SENT TO THE SERVER</string>
    <string name="privacy_server_body">Only when Backend AI or Hybrid scan mode is enabled:\n\n• Message text and sender name are sent to the ScamShield analysis server for AI scoring\n• No contact data, phone numbers or device identifiers are transmitted\n• Each request is stateless — the server retains no history\n\nIn Local engine mode, nothing leaves your device.</string>
    <string name="privacy_section_delete">HOW TO DELETE YOUR DATA</string>
    <string name="privacy_delete_body">• Threat history: Settings → Data → choose a retention period, or clear records manually in the History tab\n• Server data: Nothing is stored — each request is anonymous and discarded immediately\n• Complete removal: Uninstall ScamShield to erase the local database and all cached data from your device</string>
