<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outbound HTTP/HTTPS to the backend AI engine. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Drawing the floating scam-warning overlay above other app windows. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Foreground service so the protection process stays alive in low-memory. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Re-arm the foreground service on device boot. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Post the persistent monitoring notification on Android 13+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Required by some OEMs to keep the foreground service running. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Haptic feedback when the scam overlay fires. Normal permission — no user prompt. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Call protection: read incoming phone state + call log to analyse callers. -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <!-- Optional: enables programmatic reject when used together with CallScreeningService. -->
    <uses-permission android:name="android.permission.ANSWER_PHONE_CALLS" />
    <!-- Optional but recommended: lets ScamShield apply itself as the call-screening role. -->
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    <!-- Modify ringer for the "Mute call" quick action in the call overlay. -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <application
        android:name=".ScamShieldApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ScamShield">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ScamShield.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- NotificationListenerService: read incoming notifications from monitored apps. -->
        <service
            android:name=".service.ScamShieldNotificationService"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- AccessibilityService: read on-screen text from messaging apps + browsers. -->
        <service
            android:name=".service.ScamShieldAccessibilityService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Persistent foreground service that anchors monitoring in memory. -->
        <service
            android:name=".service.MonitoringForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- CallScreeningService: lets ScamShield intercept and analyse incoming calls. -->
        <service
            android:name=".service.ScamShieldCallScreeningService"
            android:exported="true"
            android:permission="android.permission.BIND_SCREENING_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService" />
            </intent-filter>
        </service>

        <!-- Fallback PHONE_STATE listener — fires when ScamShield is not the system screening app. -->
        <receiver
            android:name=".service.IncomingCallReceiver"
            android:exported="true">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <!-- Boot receiver to re-arm protection after reboot. -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- Handles notification action button intents (pause / resume scanning). -->
        <receiver
            android:name=".service.NotificationActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.scamshield.ACTION_PAUSE_SCAN" />
                <action android:name="com.example.scamshield.ACTION_RESUME_SCAN" />
            </intent-filter>
        </receiver>

        <!-- Quick Settings Tile: toggle ScamShield protection from the notification shade. -->
        <service
            android:name=".service.ScamShieldTileService"
            android:exported="true"
            android:icon="@drawable/ic_tile_shield_on"
            android:label="@string/tile_label_on"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- AppWidget: protection status + daily threat count on the home screen. -->
        <receiver
            android:name=".widget.ScamShieldWidget"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <!-- FileProvider for sharing generated PDF reports. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
